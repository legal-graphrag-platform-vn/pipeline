# Lấy GEMINI_API_KEY tại https://aistudio.google.com/apikey (Google AI Studio)
GEMINI_API_KEY=
# Mặc định dùng 'gemini'. Các giá trị khác: 'minimax', 'qwen', 'openai'
LLM_PROVIDER=gemini

# Cấu hình Gemini
GEMINI_MODEL=gemini-2.5-flash

# Cấu hình MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Cấu hình Qwen
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Cấu hình OpenAI (hoặc provider tương thích OpenAI khác)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Đường dẫn dữ liệu (mặc định đã hợp lý, chỉ đổi nếu cần)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# Decision Gate thresholds (ADR-06) — sẽ calibrate lại sau khi có validation set
CONFIDENCE_THRESHOLD_AUTO=0.7
CONFIDENCE_THRESHOLD_REVIEW=0.3

# OCR (Tesseract) — chỉ cần khi parse PDF dạng scan qua `parse --pdf`
# Để trống nếu tesseract.exe đã có trong PATH và gói ngôn ngữ vie đã cài sẵn trong
# thư mục tessdata mặc định (C:\Program Files\Tesseract-OCR\tessdata).
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSDATA_DIR=tessdata
